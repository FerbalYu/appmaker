{
  "extends": "./default.json",
  "env": "test",
  "server": {
    "host": "127.0.0.1",
    "port": 3001
  },
  "logging": {
    "level": "silent",
    "format": "json",
    "transports": ["memory"]
  },
  "paths": {
    "projectRoot": "./test-projects",
    "plans": "./test-plans",
    "rules": "./test-rules",
    "skills": "./test-skills",
    "logs": "./test-logs",
    "data": "./test-data"
  },
  "features": {
    "daemonMode": false,
    "autoFix": false,
    "telemetry": false
  },
  "agents": {
    "maxConcurrent": 1,
    "timeouts": {
      "planner": 30000,
      "nativeCoder": 60000,
      "nativeReviewer": 30000,
      "corrector": 45000
    }
  }
}
