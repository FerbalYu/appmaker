{
  "extends": "./default.json",
  "env": "development",
  "server": {
    "host": "localhost",
    "port": 3000,
    "reload": true
  },
  "logging": {
    "level": "debug",
    "format": "pretty"
  },
  "features": {
    "daemonMode": true,
    "autoFix": true,
    "previewMode": true
  },
  "agents": {
    "timeouts": {
      "planner": 90000,
      "nativeCoder": 180000,
      "nativeReviewer": 90000,
      "corrector": 120000
    }
  }
}
