{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "appMaker Configuration Schema",
  "type": "object",
  "required": ["app", "server", "anthropic", "paths"],
  "properties": {
    "app": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "server": {
      "type": "object",
      "required": ["host", "port"],
      "properties": {
        "host": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "cors": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "origins": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "anthropic": {
      "type": "object",
      "required": ["apiKey", "model"],
      "properties": {
        "apiKey": { "type": "string" },
        "model": { "type": "string" },
        "maxTokens": { "type": "integer", "minimum": 1 },
        "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
        "timeout": { "type": "integer", "minimum": 1000 }
      }
    },
    "agents": {
      "type": "object",
      "properties": {
        "maxConcurrent": { "type": "integer", "minimum": 1, "maximum": 10 },
        "timeouts": {
          "type": "object",
          "properties": {
            "planner": { "type": "integer" },
            "nativeCoder": { "type": "integer" },
            "nativeReviewer": { "type": "integer" },
            "corrector": { "type": "integer" }
          }
        }
      }
    },
    "paths": {
      "type": "object",
      "required": ["projectRoot", "plans", "rules", "skills"],
      "properties": {
        "projectRoot": { "type": "string" },
        "plans": { "type": "string" },
        "rules": { "type": "string" },
        "skills": { "type": "string" },
        "logs": { "type": "string" },
        "data": { "type": "string" }
      }
    },
    "logging": {
      "type": "object",
      "properties": {
        "level": { "type": "string", "enum": ["debug", "info", "warn", "error", "silent"] },
        "format": { "type": "string", "enum": ["json", "pretty", "simple"] }
      }
    },
    "features": {
      "type": "object",
      "properties": {
        "daemonMode": { "type": "boolean" },
        "autoFix": { "type": "boolean" },
        "telemetry": { "type": "boolean" },
        "previewMode": { "type": "boolean" }
      }
    }
  }
}
