{
  "planner_agent": "minimax-mcp",
  "agents": {
    "minimax-mcp": {
      "enabled": true,
      "description": "搜商 Agent - 负责调研和规划"
    },
    "native-coder": {
      "enabled": true,
      "description": "编程 Agent - 原生调用大模型完成代码编写",
      "model": "MiniMax-M2.7"
    },
    "native-reviewer": {
      "enabled": true,
      "description": "评审 Agent - 原生调用大模型完成代码审查",
      "model": "MiniMax-M2.7"
    }
  },
  "dispatcher": {
    "max_concurrent_agents": 3,
    "default_agent": "native-coder",
    "checkpoint": null
  },
  "task_defaults": {
    "retry_on_failure": true
  }
}
